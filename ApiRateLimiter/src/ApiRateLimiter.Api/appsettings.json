{
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning"
    }
  },
  "AllowedHosts": "*",
  "RateLimit": {
    "Limit": 10,
    "WindowSeconds": 60
  },
  "ConnectionStrings": {
    "RateLimit": "Server=localhost;Database=RateLimiter;Trusted_Connection=True;TrustServerCertificate=True;"
  }
}
